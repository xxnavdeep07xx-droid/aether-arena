# ============================================
# Aether Arena - Environment Configuration
# ============================================
# Copy this file to .env and fill in the values.

# ------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------
# PostgreSQL connection string (use pooler URL for Supabase)
DATABASE_URL=postgresql://user:password@localhost:5432/aether_arena
# Direct connection URL (required for Prisma migrations)
DIRECT_URL=postgresql://user:password@localhost:5432/aether_arena

# ------------------------------------------
# Discord OAuth (Optional — Social Login)
# ------------------------------------------
# Create an app at https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=https://your-domain.com/api/auth/discord/callback

# ------------------------------------------
# Session & Setup
# ------------------------------------------
# Secret for protecting the /api/setup endpoint
SETUP_SECRET=your_setup_secret_here

# ------------------------------------------
# App URL (Required for referrals & links)
# ------------------------------------------
# Your deployed domain (no trailing slash)
NEXT_PUBLIC_BASE_URL=https://your-domain.com

# ------------------------------------------
# Razorpay (Required for paid tournaments)
# ------------------------------------------
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ------------------------------------------
# Discord Bot (Optional — for mini-services)
# ------------------------------------------
DISCORD_BOT_TOKEN=your_discord_bot_token

# ------------------------------------------
# Redis (Auto-configured when you create a Redis store on Vercel)
# ------------------------------------------
# Option 1: Full Redis URL (auto-set by Vercel's pure Redis integration)
REDIS_URL=redis://default:password@host:6379
# Option 2: Individual vars (alternative)
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
# Option 3: Vercel KV / Upstash REST API (auto-set if you used Upstash)
KV_REST_API_URL=https://your-kv-url.upstash.io
KV_REST_API_TOKEN=your_kv_token

# ------------------------------------------
# Email (Gmail SMTP — for email verification)
# ------------------------------------------
# Uses your Gmail account to send emails (500 free/day)
#
# Setup steps:
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-Step Verification (required for App Password)
# 3. Go to https://myaccount.google.com/apppasswords
# 4. Create an App Password for "Mail" → use that as GMAIL_APP_PASSWORD
#
GMAIL_USER=aetherarena.999@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password_here
# Optional: Override the "From" display name/address
EMAIL_FROM=Aether Arena <aetherarena.999@gmail.com>

# ------------------------------------------
# Cron Secret (Required for Vercel Cron Jobs)
# ------------------------------------------
# Generate a random string: openssl rand -hex 32
CRON_SECRET=your_cron_secret_here
