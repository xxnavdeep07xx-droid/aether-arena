# ============================================
# Aether Arena - Environment Configuration
# ============================================
# Copy this file to .env and fill in the values.

# ------------------------------------------
# Database (SQLite)
# ------------------------------------------
# Path to the SQLite database file (relative to prisma/)
DATABASE_URL=file:./db/custom.db

# ------------------------------------------
# Discord OAuth (Optional — Social Login)
# ------------------------------------------
# Create an app at https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
# This should be your app's base URL + /api/auth/discord/callback
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback

# ------------------------------------------
# Session (Auto-generated)
# ------------------------------------------
# Used for signing session tokens. Set a random 32+ char string.
SESSION_SECRET=your_random_session_secret_here
