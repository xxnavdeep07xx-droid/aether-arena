# ============================================
# Aether Arena - Environment Configuration
# ============================================
# Copy this file to .env and fill in the values.

# ------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------
# PostgreSQL connection string (use pooler URL for Supabase)
DATABASE_URL=postgresql://user:password@localhost:5432/aether_arena
# Direct connection URL (required for Prisma migrations)
DIRECT_URL=postgresql://user:password@localhost:5432/aether_arena

# ------------------------------------------
# Discord OAuth (Optional — Social Login)
# ------------------------------------------
# Create an app at https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=https://your-domain.com/api/auth/discord/callback

# ------------------------------------------
# Session & Setup
# ------------------------------------------
# Secret for protecting the /api/setup endpoint
SETUP_SECRET=your_setup_secret_here

# ------------------------------------------
# App URL (Required for referrals & links)
# ------------------------------------------
# Your deployed domain (no trailing slash)
NEXT_PUBLIC_BASE_URL=https://your-domain.com
